{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/inspection",
      "destination": "https://rocket-inspection-app.vercel.app/inspection"
    },
    {
      "source": "/inspection/:path*",
      "destination": "https://rocket-inspection-app.vercel.app/inspection/:path*"
    }
  ]
}
