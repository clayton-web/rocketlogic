{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/login",
      "destination": "/inspection/login",
      "permanent": true
    },
    {
      "source": "/inspections",
      "destination": "/inspection/inspections",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "https://rocket-pm-dashboard-app.vercel.app/dashboard"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://rocket-pm-dashboard-app.vercel.app/dashboard/:path*"
    },
    {
      "source": "/inspection",
      "destination": "https://rocket-inspection-app.vercel.app/inspection"
    },
    {
      "source": "/inspection/:path*",
      "destination": "https://rocket-inspection-app.vercel.app/inspection/:path*"
    }
  ]
}
